{
  "prettier.enable": true,
  "prettier.configFile": ".prettierrc",
  "suggest.enablePreselect": false,
  "suggest.noselect": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": true
  },
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "typescript",
    "python",
    "typescriptreact",
    "json",
    "javascriptreact",
    "typescript.tsx",
    "graphql",
    "elixir",
    "fsharp"
  ],
  "clangd.arguments": ["--clang-tidy", "--inlay-hints=false"],
  "pyright.enable": false,
  "python.formatting.provider": "none",
  "pyright.testing.provider": "pytest",
  "python.linting.ruffEnabled": false,
  "elixir.pathToElixirLS": "~/.vscode/extensions/jakebecker.elixir-ls-0.30.0/elixir-ls-release/language_server.sh",
  "elixirLS.dialyzerEnabled": true,
  "inlayHint.enable": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "rust-analyzer.inlayHints.bindingModeHints.enable": false,
  "snippets.ultisnips.pythonPrompt": false,
  "clangd.path": "/usr/bin/clangd",
  "languageserver": {
    "odin": {
      "command": "ols",
      "filetypes": ["odin"],
      "rootPatterns": ["ols.json"]
    },
    "slint": {
      "command": "slint-lsp",
      "filetypes": ["slint"]
    },
    "c3": {
      "command": "~/.local/bin/c3-server/bin/release/c3lsp",
      "filetypes": ["c3"]
    },
    "ocaml-lsp": {
      "command": "opam",
      "args": ["config", "exec", "--", "ocamllsp"],
      "filetypes": ["ocaml", "reason"]
    },
    "ty": {
      "command": "uvx",
      "args": ["ty", "server"],
      "filetypes": ["python"],
      "rootPatterns": ["pyproject.toml", ".git"]
    },
    "ruff": {
      "command": "uvx",
      "args": ["ruff", "server"],
      "filetypes": ["python"],
      "rootPatterns": ["pyproject.toml", "ruff.toml", ".git"],
      "initializationOptions": {
        "settings": {
          "fixAll": true,
          "organizeImports": true
        }
      }
    },
    "fsharp": {
      "command": "/Users/gibsonk/.dotnet/tools/fsautocomplete",
      "args": ["--adaptive-lsp-server-enabled"],
      "filetypes": ["fsharp"],
      "rootPatterns": ["*.sln", "*.fsproj"],
      "initializationOptions": {
        "AutomaticWorkspaceInit": true,
        "workspaceModePeekDeepLevel": 4
      }
    },
    "haskell": {
      "command": "haskell-language-server-wrapper",
      "args": ["--lsp"],
      "rootPatterns": [
        "*.cabal",
        "stack.yaml",
        "cabal.project",
        "package.yaml",
        "hie.yaml"
      ],
      "filetypes": ["haskell", "lhaskell"],
      "settings": {
        "haskell": {
          "checkParents": "CheckOnSave",
          "checkProject": true,
          "maxCompletions": 40,
          "formattingProvider": "ormolu",
          "plugin": {
            "stan": {
              "globalOn": true
            }
          }
        }
      }
    }
  }
}
